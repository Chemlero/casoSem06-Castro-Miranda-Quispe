-- 7. Procedimiento almacenado para registrar salida
DELIMITER //
CREATE PROCEDURE registrar_salida(IN visita_id INT)
BEGIN
    UPDATE visita
    SET hora_salida = CURRENT_TIME()
    WHERE id_visita = visita_id;
END //
DELIMITER ;

-- 8. Vista para reportes
CREATE VIEW reporte_visitas AS
SELECT
    v.id_visita,
    p.nombre_completo AS visitante,
    p.dni,
    d.nombre_despacho,
    v.persona_visitada,
    v.fecha,
    v.hora_entrada,
    v.hora_salida,
    v.tiempo_permanencia
FROM visita v
JOIN persona p ON v.id_persona = p.id_persona
JOIN despacho d ON v.id_despacho = d.id_despacho;