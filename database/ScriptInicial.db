-- 1. Crear la base de datos
CREATE DATABASE IF NOT EXISTS sistema_visitantes;
USE sistema_visitantes;

-- 2. Tabla `persona` (visitantes y funcionarios)
CREATE TABLE IF NOT EXISTS persona (
    id_persona INT AUTO_INCREMENT PRIMARY KEY,
    nombre_completo VARCHAR(100) NOT NULL,
    dni VARCHAR(15) NOT NULL UNIQUE,
    tipo ENUM('visitante', 'funcionario') NOT NULL,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    INDEX idx_dni (dni)
) ENGINE=InnoDB;

-- 3. Tabla `despacho` (despachos de la institución)
CREATE TABLE IF NOT EXISTS despacho (
    id_despacho INT AUTO_INCREMENT PRIMARY KEY,
    nombre_despacho VARCHAR(50) NOT NULL UNIQUE,
    descripcion TEXT,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    INDEX idx_nombre_despacho (nombre_despacho)
) ENGINE=InnoDB;

-- 4. Tabla `visita` (registro de visitas)
CREATE TABLE IF NOT EXISTS visita (
    id_visita INT AUTO_INCREMENT PRIMARY KEY,
    id_persona INT NOT NULL,
    id_despacho INT NOT NULL,
    persona_visitada VARCHAR(100) NOT NULL,
    fecha DATE NOT NULL,
    hora_entrada TIME NOT NULL,
    hora_salida TIME,
    tiempo_permanencia TIME GENERATED ALWAYS AS (TIMEDIFF(hora_salida, hora_entrada)) STORED,
    FOREIGN KEY (id_persona) REFERENCES persona(id_persona) ON DELETE RESTRICT,
    FOREIGN KEY (id_despacho) REFERENCES despacho(id_despacho) ON DELETE RESTRICT,
    INDEX idx_fecha (fecha),
    INDEX idx_id_persona (id_persona),
    INDEX idx_id_despacho (id_despacho)
) ENGINE=InnoDB;

-- 5. Tabla `usuarios` (sin hasheo de contraseñas)
CREATE TABLE IF NOT EXISTS usuarios (
    id_usuario INT AUTO_INCREMENT PRIMARY KEY,
    nombre_usuario VARCHAR(50) NOT NULL UNIQUE,
    contrasena VARCHAR(50) NOT NULL,  -- Contraseña en texto plano (solo para desarrollo)
    rol ENUM('administrador', 'operador') NOT NULL,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
) ENGINE=InnoDB;

